{
  "name": "tetrix-game-backend",
  "version": "1.0.0",
  "description": "Backend API for Tetrix game with PostgreSQL and session-based auth",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:backend",
    "build:backend": "tsc",
    "build:frontend": "cd ../tetrix-game && npm run build && rm -rf ../tetrix-game-backend/dist-frontend && cp -r dist ../tetrix-game-backend/dist-frontend",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrations/migrate.ts",
    "test": "playwright test",
    "test:smoke": "BASE_URL=https://humorous-education-production-b86a.up.railway.app playwright test tests/smoke-test.spec.ts",
    "test:smoke:headed": "BASE_URL=https://humorous-education-production-b86a.up.railway.app playwright test tests/smoke-test.spec.ts --headed",
    "seed:test-user": "tsx src/scripts/seed-test-user.ts"
  },
  "keywords": [
    "tetrix",
    "game",
    "backend",
    "postgres",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.5",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@playwright/test": "^1.49.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
